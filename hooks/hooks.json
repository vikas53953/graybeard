{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/precompact_guard.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/precompact_guard.py\""
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/precompact_guard.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/precompact_guard.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/sessionstart_resume.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/sessionstart_resume.py\""
          }
        ]
      }
    ]
  }
}